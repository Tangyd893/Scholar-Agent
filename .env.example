# =============================================================================
# ScholarAgent 环境变量配置模板
# 复制此文件为 .env 并填入实际值：cp .env.example .env
# .env 已加入 .gitignore，禁止将密钥提交到版本库
# =============================================================================

# ---------------------------- LLM 配置 ----------------------------------------
# DeepSeek API Key（必填）
# 注册地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# DeepSeek 模型 ID（默认 deepseek-v4-flash）
# deepseek-chat legacy ID 将于 2026-07-24 退役，请勿使用
DEEPSEEK_MODEL=deepseek-v4-flash

# DeepSeek thinking 模式（默认 disabled，Agent 循环强制 non-thinking）
# 可选值：disabled | enabled
DEEPSEEK_THINKING=disabled

# ---------------------------- LLM 降级备选 ------------------------------------
# MiMo V2.5 Pro（可选，DeepSeek 不可用时的第一降级）
# 注册地址：https://docs.infini-ai.com/
# MIMO_API_KEY=
# MIMO_MODEL=mimo-v2.5-pro
# MIMO_BASE_URL=https://api.infini-ai.com/v1

# MiniMax-M3（可选，第二降级）
# 注册地址：https://platform.minimax.io/
# MINIMAX_API_KEY=
# MINIMAX_MODEL=minimax-m3
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ---------------------------- Agent 配置 --------------------------------------
# ReAct 推理最大步数，超出返回 error 事件（默认 5）
AGENT_MAX_STEPS=5

# 会话 TTL 天数（默认 7）
SESSION_TTL_DAYS=7

# ---------------------------- Redis 配置 --------------------------------------
# Redis 连接串（必填）
REDIS_URL=redis://localhost:6379

# ---------------------------- gRPC 服务地址 -----------------------------------
# Agent Core gRPC 监听地址
AGENT_CORE_GRPC_ADDR=localhost:50051

# Tool Service gRPC 监听地址
TOOL_SERVICE_GRPC_ADDR=localhost:50052

# ---------------------------- Gateway 配置 ------------------------------------
# Gateway HTTP 监听端口（默认 8080）
HTTP_PORT=8080

# ---------------------------- arXiv 配置 --------------------------------------
# arXiv API 请求最小间隔（毫秒，默认 3000）
ARXIV_RATE_LIMIT_MS=3000

# ---------------------------- Qdrant 配置（Phase 2）---------------------------
# Qdrant 服务地址
# QDRANT_URL=http://localhost:6333

# ---------------------------- RabbitMQ 配置（Phase 2）-------------------------
# RabbitMQ 连接串
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ---------------------------- Embedding 配置（Phase 2）------------------------
# Embedding 模型（OpenAI 兼容 API：text-embedding-3-small）
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536
# EMBEDDING_BASE_URL=https://api.deepseek.com/v1

# ---------------------------- Metrics 配置（Phase 3）--------------------------
# Prometheus 指标端口（各服务独立）
# AGENT_CORE_METRICS_PORT=9091
# TOOL_SERVICE_METRICS_PORT=9092
# GATEWAY_METRICS_PORT=9090

# ---------------------------- OCR 配置（Phase 2 可选）-------------------------
# 百度 OCR MCP（主）
# BAIDU_OCR_API_KEY=
# BAIDU_OCR_SECRET_KEY=
# PaddleOCR 本地备轨（无需配置，Docker 部署）
