{
  "annotations": { "list": [] },
  "editable": true,
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["scholar-agent"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "title": "ScholarAgent Dashboard",
  "uid": "scholar-agent",
  "panels": [
    {
      "title": "HTTP QPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "title": "LLM P95 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(llm_request_duration_seconds_bucket[1m]))",
          "legendFormat": "{{provider}}/{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Tool Calls Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(agent_tool_calls_total[5m])) by (tool_name)",
          "legendFormat": "{{tool_name}}"
        }
      ]
    },
    {
      "title": "Agent Steps per Query",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "rate(agent_steps_per_query_bucket[5m])",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "count(agent_steps_per_query_count)"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" } }
      }
    }
  ]
}
